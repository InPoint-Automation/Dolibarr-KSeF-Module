# ============================================
KSEF_ZWOLNIENIE_PODSTAWA=VAT Exemption Legal Basis
KSEF_ZWOLNIENIE_PODSTAWA_Help=Legal basis for VAT exemption, emitted when the invoice contains lines with a 0%% VAT rate that has the ZW code set in the VAT rate dictionary. Example: "art. 43 ust. 1 pkt 18 ustawy o VAT". Only applies to products/services with 0%% VAT rate using the ZW code. When disabled, invoices with ZW lines will be sent without an exemption basis.
KSEF_ZWOLNIENIE_TYPE_DISABLED=Disabled (no exemption basis)
KSEF_ZWOLNIENIE_PODSTAWA_Placeholder=e.g. art. 43 ust. 1 pkt 18 ustawy o VAT
KSEF_ZWOLNIENIE_TYPE_P19A=Polish law (ustawa)
KSEF_ZWOLNIENIE_TYPE_P19B=EU Directive
KSEF_ZWOLNIENIE_TYPE_P19C=Other legal basis
KSEF_ZWOLNIENIE_PRODUCT_FIELD=Per-Product Exemption Basis
KSEF_ZWOLNIENIE_PRODUCT_FIELD_Help=Product extrafield containing the exemption legal basis. When set, ZW invoice lines use the basis from their product instead of the global default above. Different products can have different exemption bases (e.g. art. 43 pkt 18 for medical, art. 43 pkt 26 for education). Requires extrafield type: varchar, text, or select.
KSEF_ZWOLNIENIE_PRODUCT_FIELD_DISABLED=Disabled (use global default only)
KSEF_NR_ZAMOWIENIA_SOURCE=Order/PO Number Source
KSEF_NR_ZAMOWIENIA_SOURCE_Help=Source field for the order/PO number. Default: Customer Reference (ref_client). Can also use the linked sales order number or an invoice extrafield. Requires extrafield type: varchar, text, or int.
KSEF_NR_ZAMOWIENIA_SOURCE_REF_CLIENT=Customer Reference (ref_client)
KSEF_NR_ZAMOWIENIA_SOURCE_LINKED_ORDER=Linked Sales Order Number
KSEF_NR_ZAMOWIENIA_SOURCE_DISABLED=Disabled
KSEF_NR_ZAMOWIENIA_SOURCE_EXTRAFIELD=Extrafield
KSEF_NR_UMOWY_SOURCE=Contract Number Source
KSEF_NR_UMOWY_SOURCE_Help=Source field for the contract number. Can use a third party (customer) extrafield so the contract number auto-populates from the customer record, or an invoice extrafield for per-invoice entry. Requires extrafield type: varchar, text, or int.
KSEF_NR_UMOWY_SOURCE_DISABLED=Disabled
KSEF_NR_UMOWY_SOURCE_EXTRAFIELD=Invoice extrafield
KSEF_NR_UMOWY_SOURCE_THIRDPARTY_EXTRAFIELD=Third party extrafield
KSEF_NOTE_PUBLIC_TARGET=Public Note Target
KSEF_NOTE_PUBLIC_TARGET_Help=Choose where the public note content is sent in the KSeF XML. DodatkowyOpis: key-value pairs (existing behavior). StopkaFaktury: free-text footer block. Extrafields always go to DodatkowyOpis regardless of this setting.
KSEF_NOTE_PUBLIC_TARGET_DODATKOWY_OPIS=DodatkowyOpis (additional description - key/value)
KSEF_NOTE_PUBLIC_TARGET_STOPKA_FAKTURY=StopkaFaktury (invoice footer - free text)
KSEF_STOPKA_FAKTURY_SECTION=Invoice Footer (StopkaFaktury)
KSEF_STOPKA_BOILERPLATE=Footer Boilerplate Text
KSEF_STOPKA_BOILERPLATE_Help=Static text appended to every outgoing invoice footer. Typical content: KRS registration, GDPR clause, capital info, legal disclaimers. Maximum 3500 characters per the FA(3) schema.
KSEF_STOPKA_BOILERPLATE_Limit=Maximum 3500 characters

KSEF_DEFAULT_PAYMENT_CONFIG=Default Invoice Payment Settings
KSEF_DEFAULT_PAYMENT_TERM=Default Payment Terms
KSEF_DEFAULT_PAYMENT_TERM_Help=Pre-fill payment terms when creating a new invoice. Used when the customer has no payment terms configured and no source document (order/proposal) is linked. Can always be changed per invoice.
KSEF_DEFAULT_PAYMENT_METHOD=Default Payment Method
KSEF_DEFAULT_PAYMENT_METHOD_Help=Pre-fill payment method when creating a new invoice. Used when the customer has no payment method configured and no source document is linked. Can always be changed per invoice.
KSEF_DEFAULT_BANK_ACCOUNT=Default Bank Account
KSEF_DEFAULT_BANK_ACCOUNT_Help=Pre-fill bank account when creating a new invoice. Used when the customer has no bank account configured and no source document is linked. Can always be changed per invoice.

KSEF_VAT_DICTIONARY_HELPER=KSeF VAT Rate Codes
KSEF_VAT_DICTIONARY_HELPER_Help=KSeF uses specific codes to distinguish 0%% VAT types (exempt, reverse charge, not subject, WDT, export). Enable the codes your business needs - they will appear in the VAT rate dropdown when creating invoice lines. Standard 0%% (without a code) is always available and auto-detected by buyer country.
KSEF_VAT_DICTIONARY_HELPER_Desc=Enable or disable available VAT rates on invoices
